generator client {
  provider      = "prisma-client-js"
  // Важливо для Render (вирішує проблему Permission denied)
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  username     String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tasks         Task[] @relation("TaskUser")
  createdTasks  Task[] @relation("TaskCreator")
  assignedTasks Task[] @relation("TaskAssignee")

  // Groups
  ownedGroups  Group[] @relation("GroupOwner")
  memberGroups Group[] @relation("GroupMember")
}

model Group {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Owner
  ownerId String
  owner   User   @relation("GroupOwner", fields: [ownerId], references: [id])

  // Members (many-to-many)
  members User[] @relation("GroupMember")

  tasks Task[]
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?

  // Relations
  userId String
  user   User   @relation("TaskUser", fields: [userId], references: [id], onDelete: Restrict)

  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id])

  creatorId String
  creator   User   @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Restrict)

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
}
